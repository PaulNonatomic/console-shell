{
	"name": "console-quest",
	"version": "0.1.0",
	"description": "Brand-styled developer-console shells and branching text adventures for the web. Hide a CLI in your dev tools.",
	"keywords": [
		"console",
		"easter-egg",
		"text-adventure",
		"interactive-fiction",
		"dev-tools",
		"cli",
		"branding"
	],
	"author": "Paul Stamp <paul@nonatomic.co.uk> (https://nonatomic.co.uk)",
	"license": "MIT",
	"homepage": "https://github.com/PaulNonatomic/console-quest",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PaulNonatomic/console-quest.git"
	},
	"bugs": {
		"url": "https://github.com/PaulNonatomic/console-quest/issues"
	},
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "npm run build && npm run test && npm run typecheck"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"jsdom": "^29.1.1",
		"tsup": "^8.3.0",
		"typescript": "^5.7.0",
		"vitest": "^2.1.0"
	},
	"sideEffects": false,
	"engines": {
		"node": ">=18"
	}
}
